// This is a test diagram with comments
diagram {
    /* This is a block comment
       spanning multiple lines */
    box mainbox {
        title: "Main Box" // inline comment

        box child1 {
            title: "Child 1"
            color: blue // This is blue
        }

        /* Another block comment */
        box child2 {
            title: "Child 2"
            color: red
        }
    }
}

// Layout section
layout {
    size: (500, 400) // Canvas size (width, height)

    // Main container box
    mainbox {
        pos: (50, 50) // (x, y)
        size: (400, 300) // (width, height)
    }

    // First child box
    child1 {
        pos: (70, 100) // (x, y)
        size: (150, 80) // (width, height)
    }

    // Second child box
    child2 {
        pos: (250, 100) // (x, y)
        size: (150, 80) // (width, height)
    }
}

