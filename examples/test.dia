version = 0.1.0

diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stacked: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
            }
        }
        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
            }
        }
    }

    box cdc {
        title: "CDC" vertical
        color: blue
    }
}

layout {
    size: (1533, 788)
    scale: 50%

    top {
        pos: (40, 30) // (x, y)
        size: (1450, 725) // (width, height)
    }
    entropy {
        pos: (75, 65)
        size: (420, 285)
    }
    trngDb {
        pos: (115, 105)
        size: (340, 220)
    }
    trace {
        pos: (535, 65)
        size: (420, 630)
    }
    traceFunnel {
        pos: (575, 95)
        size: (300, 160)
    }
    traceSink {
        pos: (575, 505)
        size: (340, 160)
    }
    debug {
        pos: (995, 65)
        size: (420, 630)
    }
    innerDebug {
        pos: (1035, 95)
        size: (340, 250)
    }
    debug2 {
        pos: (1035, 380)
        size: (340, 285)
    }
    cdc {
        pos: (75, 380)
        size: (115, 315)
    }
}
