version = 0.1.0

diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
                port trngOscIn {
                    side: right
                }
                port entropyOut {
                     side: left
                }
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stacked: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
            }
        }

        box cdc {
            title: "CDC" vertical
            color: blue
            port cdcOut {
                side: left
            }
        }

        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
            }
        }

        port pinstrapsIn {
            side: right
        }
    }

    port pinstrapsSource {
        title: "pinstraps WGPort, secure tieoffs"
    }

    port oscSource {
        title: "OSC"
    }

    port entropySink {
         // no title: attribute is required
    }

    port cdcSink {
        title: "CDC Sink"
    }

    arrow {
        from: pinstrapsSource
        to: pinstrapsIn
    }

    arrow {
        from: oscSource
        to: trngOscIn
    }

    arrow {
        from: entropyOut
        to: entropySink
    }

    arrow {
        from: cdcOut
        to: cdcSink
    }
}

layout {
    size: (3000, 1600)
    scale: 35%

    top {
        pos: (600, 200) // (x, y)
        size: (1300, 1350) // (width, height)
    }
    entropy {
        pos: (300, 200)
        size: (900, 300)
    }
    trngDb {
        pos: (100, 50)
        size: (340, 200)
    }
    trace {
        pos: (300, 550)
        size: (950, 400)
    }
    traceFunnel {
        pos: (40, 30)
        size: (360, 306)
    }
    traceSink {
        pos: (480, 30)
        size: (387, 306)
    }
    debug {
        pos: (300, 1000)
        size: (950, 130)
    }
    innerDebug {
        pos: (40, 20)
        size: (400, 80)
    }
    debug2 {
        pos: (480, 20)
        size: (430, 80)
    }
    cdc {
        pos: (150, 550)
        size: (115, 315)
    }
    pinstrapsSource {
        pos: (2200, 335)
    }
    pinstrapsIn {
        interp: 10%
    }
    oscSource {
        pos: (2200, 550)
    }
    trngOscIn {
        interp: 50%
    }
    entropySink {
        pos: (100, 470)
    }
    entropyOut {
        interp: 10%
    }
    cdcSink {
        pos: (500, 907)
    }
    cdcOut {
        interp: 50%
    }
}
