version = 0.1.0

diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
                port trngOscIn {
                    side: right
                }
                port entropyOut {
                     side: left
                }
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stacked: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
                port outerTraceClock {
                    side: right
                }
                port atbPib {
                    side: right
                }
            }
        }

        box cdc {
            title: "CDC" vertical
            color: blue
            port cdcOut {
                side: left
            }
        }

        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
                port debugIn2 {
                    side: right
                }
            }
        }

        port pinstrapsIn {
            side: right
        }
    }

    port pinstrapsSource {
        title: "pinstraps WGPort, secure tieoffs"
    }

    port oscSource {
        title: "OSC"
    }

    port entropySink {
         // no title: attribute is required
    }

    port cdcSink {
        title: "CDC Sink"
    }

    port traceClockSource {
        title: "Trace Clock Source"
    }

    port atbPibSink {
        title: "ATB PIB Sink"
    }

    port debugSink2 {
        title: "Debug Sink 2"
    }

    arrow {
        from: pinstrapsSource
        to: pinstrapsIn
    }

    arrow {
        from: oscSource
        to: trngOscIn
    }

    arrow {
        from: entropyOut
        to: entropySink
    }

    arrow {
        from: cdcOut
        to: cdcSink
    }

    arrow {
        from: traceClockSource
        to: outerTraceClock
    }

    arrow {
        from: atbPib
        to: atbPibSink
    }

    arrow {
        from: debugIn2
        to: debugSink2
    }
}

layout {
    size: (3000, 1600)
    scale: 35%
    fontsize: 40

    top {
        pos: (600, 200) // (x, y)
        size: (1300, 1350) // (width, height)
    }
    entropy {
        pos: (300, 200)
        size: (900, 300)
    }
    trngDb {
        pos: (100, 50)
        size: (340, 200)
    }
    trace {
        pos: (300, 550)
        size: (950, 400)
    }
    traceFunnel {
        pos: (40, 80)
        size: (360, 256)
    }
    traceSink {
        pos: (480, 80)
        size: (387, 256)
    }
    debug {
        pos: (300, 1000)
        size: (950, 180)
    }
    innerDebug {
        pos: (40, 70)
        size: (400, 80)
    }
    debug2 {
        pos: (480, 70)
        size: (430, 80)
    }
    cdc {
        pos: (150, 550)
        size: (115, 315)
    }
    pinstrapsSource {
        pos: (2200, 335)
    }
    pinstrapsIn {
        interp: 10%
    }
    oscSource {
        pos: (2200, 550)
    }
    trngOscIn {
        interp: 50%
    }
    entropySink {
        pos: (100, 550)
    }
    entropyOut {
        interp: 50%
    }
    cdcSink {
        pos: (500, 907)
    }
    cdcOut {
        interp: 50%
    }
    outerTraceClock {
        interp: 25%
    }
    atbPib {
        interp: 75%
    }
    traceClockSource {
        pos: (2200, 894)
    }
    atbPibSink {
        pos: (2200, 1022)
    }
    debugIn2 {
        interp: 50%
    }
    debugSink2 {
        pos: (2200, 1310)
    }
}
