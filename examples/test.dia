diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stack: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
            }
        }
        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
            }
        }
    }

    box cdc {
        title: "CDC" vertical
    }
}

layout {
    size: (600, 600)

    top {
        pos: (10, 10) // (x, y)
        size: (570, 570) // (width, height)
    }
    entropy {
        pos: (20, 10)
        size: (10, 10)
    }
    trngDb {
        pos: (40, 10)
        size: (10, 10)
    }
    trace {
        pos: (0, 0)
        size: (10, 10)
    }
    traceFunnel {
        pos: (0, 0)
        size: (10, 10)
    }
    traceSink {
        pos: (0, 0)
        size: (10, 10)
    }
    debug {
        pos: (0, 0)
        size: (10, 10)
    }
    innerDebug {
        pos: (0, 0)
        size: (10, 10)
    }
    debug2 {
        pos: (0, 0)
        size: (10, 10)
    }
    cdc {
        pos: (0, 0)
        size: (10, 10)
    }
}
