diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stack: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
            }
        }
        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
            }
        }
    }

    box cdc {
        title: "CDC" vertical
        color: blue
    }
}

layout {
    size: (3066, 1576)

    top {
        pos: (80, 60) // (x, y)
        size: (2900, 1450) // (width, height)
    }
    entropy {
        pos: (150, 130)
        size: (840, 570)
    }
    trngDb {
        pos: (230, 210)
        size: (680, 440)
    }
    trace {
        pos: (1070, 130)
        size: (840, 1260)
    }
    traceFunnel {
        pos: (1150, 190)
        size: (680, 320)
    }
    traceSink {
        pos: (1150, 1010)
        size: (680, 320)
    }
    debug {
        pos: (1990, 130)
        size: (840, 1260)
    }
    innerDebug {
        pos: (2070, 190)
        size: (680, 500)
    }
    debug2 {
        pos: (2070, 760)
        size: (680, 570)
    }
    cdc {
        pos: (150, 760)
        size: (230, 630)
    }
}
