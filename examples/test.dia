diagram {
    box top {
        box entropy {
            title: "Entropy"
            box trngDb {
                title: "TRNG-DB"
                color: blue
            }
        }

        box trace {
            title: "Trace"
            box traceFunnel {
                title: "Trace Funnel"
                color: blue
                stack: 3
            }

            box traceSink {
                title: "Trace Sink"
                color: red
            }
        }
        box debug {
            title: "Debug"
            box innerDebug {
                title: "Inner Debug"
                color: yellow
            }

            box debug2 {
                title: "Debug"
                color: pink
            }
        }
    }

    box cdc {
        title: "CDC" vertical
    }
}

layout {
    size: (600, 600)

    top {
        pos: (10, 10) // (x, y)
        size: (570, 570) // (width, height)
    }
    entropy {
        pos: (30, 30)
        size: (160, 160)
    }
    trngDb {
        pos: (50, 50)
        size: (120, 120)
    }
    trace {
        pos: (210, 30)
        size: (160, 250)
    }
    traceFunnel {
        pos: (230, 50)
        size: (120, 60)
    }
    traceSink {
        pos: (230, 200)
        size: (120, 60)
    }
    debug {
        pos: (390, 30)
        size: (160, 250)
    }
    innerDebug {
        pos: (410, 50)
        size: (120, 100)
    }
    debug2 {
        pos: (410, 170)
        size: (120, 90)
    }
    cdc {
        pos: (30, 400)
        size: (80, 150)
    }
}
