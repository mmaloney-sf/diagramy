// Example 6: Multi-line Text
// Text can span multiple lines for better readability
// Each line is specified separately and will be rendered on its own line
diagram {
    width: 500
    color: white
    title: "Multi-line Text Demo"
    top: Top
}

box Top {
    grid: 2x2

    // Single-line text
    box at (1, 1) is {
        color: red
        label "Single Line"
    }

    // Two-line text
    box at (1, 2) is {
        color: green
        label "First Line"
              "Second Line"
    }

    // Three-line text
    box at (2, 1) is {
        color: blue
        label "Line 1"
              "Line 2"
              "Line 3"
    }

    // Multi-line text with longer content
    box at (2, 2) is {
        color: yellow
        label "Memory"
              "Controller"
              "Unit"
              "v2.0"
    }
}
