version = 0.1.0

diagram {
    box top {
        title: "Top"

        box foo {
            title: "Foo"
            color: red
        }

        box bar {
            title: "Bar"
            color: blue
        }
    }
}

layout {
    size: (800, 600)

    top {
        pos: (50, 50)
        size: (700, 500)
    }
    foo {
        pos: (25, 25)
        size: (100, 200)
    }
    bar {
        pos: (200, 25)
        size: (100, 200)
    }
}
