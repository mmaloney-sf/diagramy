// Example 16: Labels
// Labels are a convenient way to add text without creating full boxes
// They support multi-line text and optional positioning

diagram {
    debug: true
    width: 512
    color: white
    title: "Label Example"
    top: Top
}

box Top {
    grid: 2x4

//    label "test"
    box is {
        grid: 2x2
        color: green
        box at (2, 1) is {
            color: blue
        }
    }
}
