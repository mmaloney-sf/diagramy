diagram {
    width: 300
    color: white
    top: labels
}

box box_number_0 {
    grid: 2x2
    box is box_number_1
    box is box_number_1
    box is box_number_1
    box is box_number_1
}

box box_number_1 {
    grid: 1x1

    port a at (0.5, 0.0)
    port b at (0.5, 1.0)

    arrow a to b
}

box labels {
    grid: 2x2
    borderStyle: dashed

    label "hello"
    label "world"
    label "hello labels"  dim 1x2
}
